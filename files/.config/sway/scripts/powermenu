#!/usr/bin/env bash
echo -e "Lock ´æû\nPoweroff ´Çæ\nReboot ¯½Æ\nSuspend ¾░ñä\nLogout ¯®«" \
  | fuzzel --dmenu --prompt="ÔÜí Power:" \
  | {
      read opcion
      case "$opcion" in
        "Lock ´æû" ) hyprlock ;;
        "Poweroff ´Çæ") systemctl poweroff ;;
        "Reboot ¯½Æ") systemctl reboot ;;
        "Suspend ¾░ñä") hyprlock sleep 0.5 
                     swayidle -w before-sleep '' & 
                     systemctl suspend ;;
        "Logout ¯®«") kill -9 -1 ;;
        *) exit ;;
      esac
    }

